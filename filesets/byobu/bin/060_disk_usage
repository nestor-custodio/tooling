#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

source "$( script-path )/status_helpers.lib"


# Note we're producing string output where each character is one of:
#
system_block='#[fg=red]⠿'      # (a "system data" block)
user_block='#[fg=orange]⠿'     # (a "user data" block)
fscache_block='#[fg=yellow]⠒'  # (an "fscache data" block)
free_block='#[fg=green]⠒'      # (a "free space" block)
#
# ... with a bar of length:
#
length='10'
#
# All output here is driven by the above values. Customizing the bar length
# and the different characters and their formatting should take nothing else.


df --type='ext4' --block-size='1' --output='size,avail' --total | tail -n1 | store-as total free

# A single `du` call for both locations is faster than 2 separate calls.
#
user_root='/home'
fscache_root='/var/cache/fscache'
#
sudo du --bytes --summarize --one-file-system "$user_root" "$fscache_root" 2> /dev/null | store-as all_usage
#
grep -F "$user_root" <<< "$all_usage" | cut -f1 | store-as user
[ -n "$user" ] || user=0
#
grep -F "$fscache_root" <<< "$all_usage" | cut -f1 | store-as fscache
[ -n "$fscache" ] || fscache=0

calc "${total} - (${user} + ${fscache} + ${free})" | store-as system


calc "ceil ( ${system}  / ${total} * ${length} )" | store-as system_blocks
calc "ceil ( ${user}    / ${total} * ${length} )" | store-as user_blocks
calc "ceil ( ${fscache} / ${total} * ${length} )" | store-as fscache_blocks
calc "floor( ${free}    / ${total} * ${length} )" | store-as free_blocks


left-piped " \uf487 %s%s%s%s" "$( seq "$system_blocks"  | map printf "$system_block"  2>/dev/null )" \
                              "$( seq "$user_blocks"    | map printf "$user_block"    2>/dev/null )" \
                              "$( seq "$fscache_blocks" | map printf "$fscache_block" 2>/dev/null )" \
                              "$( seq "$free_blocks"    | map printf "$free_block"    2>/dev/null )"
