#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name ) [MOUNT_POINT]

		Unmounts the S3 bucket currently mounted onto the MOUNT_POINT.
		If no MOUNT_POINT is given, the default is "~/s3".


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option,
		  2  if failed to unmount,
		  3  if failed to clean up.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.
		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	mount_point="${HOME}/s3"
	[ "$#" -ge 1 ] && mount_point="$1" && shift
	[ -n "$mount_point" ] || user-error 1 'empty MOUNT_POINT'


	[ "$#" == 0 ] || user-error 1 'invalid option(s)'

}

# ---
# ---


if 's3?' "$mount_point"; then
	sync "$mount_point"
	fusermount -u "$mount_point" || non-user-error 2
fi

[ -d "$mount_point" ] && { rmdir "$mount_point" &> /dev/null || non-user-error 3 ;}
exit 0
