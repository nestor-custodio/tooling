#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name )

		Reports on the presence of *any* running Spring server.
		(The server found may not necessarily be a shell-detached one.)


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if service is running,
		  1  if service is not running (or invalid option).
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.
		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	[ "$#" == 0 ] || user-error 1 'invalid option(s)'

}

# ---
# ---


pwd | 'starts-with?' "$DEV_ROOT" || user-error 3 "not currently within '${DEV_ROOT}'"
cd "$DEV_ROOT"

command -v spring &> /dev/null || exit 1

spring status | store-as status
echo "$status" &> /dev/stderr

'has?' 'is running' <<< "$status"
