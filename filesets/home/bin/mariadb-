#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name )

		On MariaDB VM: stops the 'mariadb' container.
		On all other VMs: shuts down the MariaDB VM.


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.
		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	[ "$#" == 0 ] || user-error 1 'invalid option(s)'

}

# ---
# ---


# Bail if not already running.
#
'mariadb?' || exit 0


if [ "$( instance name )" == 'mariadb' ]; then

	# We're *on* the 'mariadb' instance = stop the service.
	#
	docker compose --file="$( script-real ).yaml" down 2> /dev/null

else

	# We're on a MariaDB consumer = stop the 'mariadb' instance.
	#
	gcp shutdown mariadb

fi
