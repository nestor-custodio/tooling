#! /bin/env bash
shopt -s lastpipe expand_aliases
source '/home/nestor/bin/set-path.src'

# ---


# -- Misc Helpers -- #


	SCRIPT_TIMESTAMP="$( date '+%s.%N' )"
	function script-date { date --date="@${SCRIPT_TIMESTAMP}" "+${1:-%Y-%m-%d}" ;}
	function script-duration { bc --quiet --mathlib <<< "$( date '+%s.%N' ) - ${SCRIPT_TIMESTAMP}" ;}


	alias store-as="read -r -d ''"

	function script-file { echo     "$0" ;}
	function script-path { dirname  "$0" ;}
	function script-real { realpath "$0" ;}
	function script-name { basename "$0" ;}

	function file-blanks { script-file | sed -e 's|.| |g' ;}
	function path-blanks { script-path | sed -e 's|.| |g' ;}
	function real-blanks { script-real | sed -e 's|.| |g' ;}
	function name-blanks { script-name | sed -e 's|.| |g' ;}


	STARTUP_DIR="$( pwd )"
	function reset-to-startup-dir { cd "$STARTUP_DIR" || exit 99 ;}

	function cd-to-script   { cd "$(             script-path    )" ;}
	function cd-to-realpath { cd "$( dirname "$( script-real )" )" ;}


	TMPDIR="${TMPDIR:-/tmp}"
	function tempname { mktemp --dry-run -t "$( script-name ).XXX" ;}


	LOGDIR='/var/log'
	function logfile {
		local filename="$1" && shift
		[ -n "$filename" ] || filename="${LOGDIR}/$( script-name )"

		{
			sudo touch                      "$filename" \
			&& sudo chmod 666               "$filename" \
			&& sudo chown "${USER}:${USER}" "$filename"
		} || non-user-error 99 'unable to create logfile'

		echo "$filename"
	}


	# `notify`-es via 'pushover' CHANNEL, with the `script-name` as the SUBJECT.
	# Supports both the param and the piped MESSAGE use of `notify`.
	#
	function notify-from-script { notify 'pushover' "$( script-name )" "$@" ;}


	# Prints "usage" text and exits.
	#
	# This used to be generated via `exit-out "$usage"`, but when that became
	# `non-user-error "$usage"`, the call became misleadingly named.
	#
	function help-and-exit { echo "$usage"; exit 0 ;}


# -- IO Helpers -- #


	TAB=$'\t'
	NEWLINE=$'\n'


	function interactive? { [ -t 0 ] ;}
	function piped-input? { [ -p /dev/stdin ] ;}
	function stdin-fuckery? { [ ! -t 0 ] && [ ! -p /dev/stdin ] ;}


	function backspace { seq "${1:-1}" | xargs -I {} printf '\b \b' ;}

	function clear-line { printf '\e[2K\e[1G' ;}

	# Pauses for a key press.
	# Takes a single, optional param: the prompt to display.
	#
	function pause {
		# Note this is NOT the same as `local prompt="${1:-...}"`.
		#
		local prompt
		if [ "$#" == 0 ]
			then prompt='Press any key to continue ...'
			else prompt="$1" && shift
		fi

		read -r -n1 -s -p "$prompt" && echo
	}


# -- Error Helpers -- #


	declare -A _pre_trap_flags

	# Allows simplified setting of traps by
	# automatically managing any related shell flags.
	#
	function set-trap {
		local signal="$1" && shift
		local processor="$1" && shift


		# Remember the inital state of relevant shell flags,
		# then set as required to accomodate the requested trap.

		case "$signal" in

			ERR)
				# shellcheck disable=SC2016
				set +o | grep -P '\b(errexit|pipefail)\b' | store-as '_pre_trap_flags["$signal"]'
				set -o errexit
				set -o pipefail
				;;

		esac


		# shellcheck disable=SC2064
		trap "$processor" "$signal"
	}

	# Resets traps for the given signal, and restores
	# any related shell flags that may have been tweaked.
	#
	function clear-trap {
		local signal="$1" && shift

		trap - "$signal"
		eval "${_pre_trap_flags["$signal"]}"; unset '_pre_trap_flags["$signal"]'
	}

	# Allow for a rudimentary debug mode, where every command is printed to STDERR as it runs,
	# and then waits for user input (<enter>) before continuing to the next line in the script.
	#
	alias DEBUG!='printf "\nSwitching to DEBUG.\nPress <ENTER> to continue..."; set-trap debug "read -u1"; set -x'
	alias DEBUG-='set +x; clear-trap debug'

	# ---

	# Prints an error message -- with caller context and additional help text -- to STDERR, then exits.
	#
	function user-error {
		local exit_code=''
		local error_message='unspecified error'

		case "$#" in
			1)
				local single_param="$1" && shift
				if [ -z "${single_param//[0-9]/}" ]
					then exit_code="$single_param"
					else non-user-error 99 'improperly reported error'
				fi
				;;

			2)
				exit_code="$1" && shift
				error_message="$1" && shift
				;;

			*)
				non-user-error 99 'improperly reported error'
				;;
		esac


		cat <<-EOF >& 2
			$( script-name ): ${error_message}
			Try '$( script-name ) --help' for more information.
		EOF

		exit "$exit_code"
	}


	# Prints an (optional) error message -- as given -- to STDOUT, then exits.
	#
	# NOTE: Scripts that report a boolean state should not `non-user-error` that value out.
	#       That exit value is not an *error*, and should be generated via `exit 0` / `exit 1`.
	#
	function non-user-error {
		local exit_code=''
		local error_message=''

		case "$#" in
			1)
				local single_param="$1" && shift
				if [ -z "${single_param//[0-9]/}" ]
					then exit_code="$single_param"
					else non-user-error 99 'improperly reported error'
				fi
				;;

			2)
				exit_code="$1" && shift
				error_message="$1" && shift
				;;

			*)
				non-user-error 99 'improperly reported error'
				;;
		esac


		[ -n "$error_message" ] && echo "$error_message" >& 2
		exit "$exit_code"
	}


# -- Parameter Processing -- #


	# Blind checks for a '--help' param.
	# Note these DO NOT MODIFY THE PARAM LIST.
	#
	# shellcheck disable=SC2142
	alias 'help-param?'='printf "%s\n" -- "$@" | grep -x --quiet -- "--help"'
	#
	# shellcheck disable=SC2142
	alias 'help-param-only?'='[ "$*" == "--help" ]'

	# Modifies the param list to facilitate processing.
	#
	# shellcheck disable=SC2142
	alias set-params='{

		# (https://stackoverflow.com/a/29754866/4905941)

		# This param preprocessing code expects that both
		# CHAR_OPTS and LONG_OPTS have already been set, per the above.

		PARSED="$( getopt -o "$CHAR_OPTS" -l "$LONG_OPTS" -- "$@" 2> /dev/null )" || user-error 1 "invalid option(s)"
		eval set -- "$PARSED"

	}'
