#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name ) [FILE ...] [--into=TARGET_DIR]

		Reconstructs the source TAR archive from the given QR-scanned FILE(s)
		(or STDIN) and extracts it into the given TARGET_DIR (defaults to "./").


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option,
		  2  if incomplete data,
		  3  if unable to process.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	# Set defaults.

	target_dir='./'

	# ---
	# ---

	CHAR_OPTS=''
	LONG_OPTS='help,into:'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.


			(--into)
				target_dir="$1" && shift
				[ -n "$target_dir" ] || user-error 1 "invalid TARGET_DIR"
				mkdir -p "$target_dir" || user-error 1 "unwritable TARGET_DIR"
				;;

		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	case "$#" in

		0)
			store-as data
			;;

		*)
			cat "$@" 2> /dev/null | store-as data
			;;

	esac

}

# ---
# ---


# Read data.
#
total_parts='1'
declare -a part_data
while read data_line; do
	[ -n "$data_line" ] || continue

	sed -r -e 's|^.*:0*([0-9]+)/0*([0-9]+) # (.*)$|\1 \2 \3|' <<< "$data_line" | read part_number total_parts part_content
	part_data["$part_number"]="$part_content"
done <<< "$data"

# Verify completeness.
#
if ! calc? "${total_parts} == ${#part_data[@]}"; then
	non-user-error 2 "incomplete data: ${total_parts} part(s) expected; ${#part_data[@]} given"
fi

# Process completed horcrux.
#
base64 --decode --ignore-garbage <<< "${part_data[@]}" | decrypt | gunzip \
| tar --extract --directory="$target_dir" --transform='s|.*/||' || non-user-error 3 "unable to process"
