#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name )

		Starts a local, dockerized MariaDB container.


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option,
		  2  if unable to create persistent storage.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) exit-out "$usage" ;;
			(--) break ;;  # No more options.
		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	[ "$#" == 0 ] || error-out 1 'invalid option(s)'

}

# ---
# ---


# Bail if already running.
#
'mariadb?' && exit-out 0


if [ "$( instance name )" == 'mariadb' ]; then

	# We're *on* the 'mariadb' instance = stop the service.

	export ROOTPASS="$( creds databases/logins/mariadb/root )"
	export USERNAME="$USER"
	export PASSWORD="$( creds databases/logins/mariadb/"$USER" )"
	export DATABASE="$USER"

	export DB_STORE="${HOME}/database/data"
	export DB_STORE_UID="$( id -u )"
	export DB_STORE_GID="$( id -g )"


	mkdir -p "$DB_STORE" || exit-out 2
	docker compose --file="$( script-real ).yaml" up --detach

else

	# We're on a MariaDB consumer = start the 'mariadb' instance + service.
	#
	[ "$( gcp state mariadb )" == 'RUNNING' ] || !! gcp up mariadb
	gcp run mariadb mariadb+

fi
