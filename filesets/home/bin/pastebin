#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name ) URL_OR_ID
		       $( name-blanks ) ID_WORD_1 ID_WORD_2

		Takes a pastebin URL_OR_ID (or an ID as two separate words) and dumps
		its contents out to STDOUT. (See https://paste.c-net.org/ for details.)


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) exit-out "$usage" ;;
			(--) break ;;  # No more options.
		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	case "$#" in

		1)
			url_or_id="$1" && shift
			[ -n "$url_or_id" ] || error-out 1 'no URL_OR_ID given'
			;;

		2)
			id_word_1="$1" && shift
			[ -n "$id_word_1" ] || error-out 1 'no ID_WORD_1 given'

			id_word_2="$1" && shift
			[ -n "$id_word_2" ] || error-out 1 'no ID_WORD_2 given'

			url_or_id="${id_word_1}${id_word_2}"
			;;

		*)
			error-out 1 'invalid option(s)'
			;;

	esac

}

# ---
# ---


# (https://paste.c-net.org/)

pastebin_url='https://paste.c-net.org/'
curl -s "${pastebin_url}${url_or_id##*/}"
