#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name ) [ARGS]

		Ensures 'pipx' is available.
		If any ARGS are given, 'pipx' is then invoked with the given ARGS.

		NOTE: To allow passing ARGS through to 'pipx', the '--help' flag
		      will only output this help text when it's the *only* param given.


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK.
	EOF

}

# ---

{ # -- Parameter Processing: Positionals -- #

	help-param-only? && { echo "$usage"; exit-out 0 ;}

}

# ---
# ---


if [ "$#" == 0 ]; then

	# Install 'pipx' (visibly), if needed.
	#
	command -V pipx &> /dev/null || sudo apt-get -qqy install pipx

else

	# Install 'pipx' (quietly), if needed.
	#
	command -V pipx &> /dev/null || sudo apt-get -qqy install pipx &> /dev/null

	# Run `pipx` with the given ARGS.
	#
	pipx "$@"

fi
