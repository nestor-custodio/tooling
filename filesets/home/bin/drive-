#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name )

		Unmounts the Google Drive location currently mounted onto "~/drive".


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option,
		  2  if failed to unmount,
		  3  if failed to clean up.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.
		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	[ "$#" == 0 ] || user-error 1 'invalid option(s)'

}

# ---
# ---


mount_point="${HOME}/drive"

if 'drive?'; then
	sync "$mount_point"
	fusermount -u "$mount_point" || non-user-error 2
fi

[ -d "$mount_point" ] && { rmdir "$mount_point" &> /dev/null || non-user-error 3 ;}
exit 0
