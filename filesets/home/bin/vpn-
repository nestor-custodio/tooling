#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name ) NETWORK

		Terminates the active VPN connection (if any) to the given NETWORK.


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option,
		  2  if invalid NETWORK.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.
		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	network="$1" && shift
	[ -n "$network" ] || user-error 1 'no NETWORK given'


	[ "$#" == 0 ] || user-error 1 'invalid option(s)'

}

# ---
# ---


# Bail if there is no VPN host.
#
[ "$( gcp state vpn )" == 'RUNNING' ] || exit 0


# Ensure the given NETWORK exists.
#
network_bins="${HOME}/vm-scripts/vpn/bin/${network}"
[ -d "$network_bins" ] || user-error 2 "unknown NETWORK: '${network}'"


ssh -n nestor@vpn -- "${network_bins}/disconnect"
