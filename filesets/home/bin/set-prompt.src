#! /bin/env bash
shopt -s lastpipe

# ---

# Differentiate between root and non-root users.
#
if [ "$( id -u )" == 0 ]
	then export PS1='($?) \[\033[01;31m\]\u@\h\[\033[00m\] \[\033[01;34m\]\w\[\033[00m\] \$'
	else export PS1='($?) \[\033[01;32m\]\u@\h\[\033[00m\] \[\033[01;34m\]\w\[\033[00m\] \$'
fi


# `asciinema` subshells get a special indicator so we don't forget we're in "record" mode.
#
[ -n "$ASCIINEMA_REC" ] && PS1="[ \[\033[31m\]\[\033[00m\] \[\033[05m\]REC\[\033[00m\] ]  ${PS1}"
