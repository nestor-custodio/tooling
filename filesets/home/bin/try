#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name ) PROMPT [-- SC_OPTIONS]

		Wrapper for SmartCat ('sc') that starts a new "conversation" with the
		given PROMPT (which need not be quoted as a single string).
		(e.g.: '$( script-name ) making this more legible < file.sh')

		Issue follow-up prompts with 'kbut' to continue the "conversation".


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.
		esac
	done

}

# ---
# ---


sc "$( script-name ) $*"
