#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name ) LOCATION [--onto MOUNT_POINT]

		Mounts an S3 LOCATION onto the given MOUNT_POINT.
		If no MOUNT_POINT is given, the default is "~/s3".

		The LOCATION may be a full 'rclone mount'-able "remote:/path" value
		(e.g. 'aws_credentials_remote:/bucket_name/path_to_mount') or an alias
		that translates to one. If no ':' is present in the given LOCATION, ':/'
		will be appended; this allows for easy use of "user + bucket" aliases by
		just the name alone (in which case the bucket *root* is mounted).


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.
		  --no-cache                Disable VFS caching to facilitate streaming.


		Exit Status:
		  0  if OK,
		  1  if invalid option,
		  2  if invalid remote,
		  3  if failed to mount.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	# Set defaults.

	mount_point="${HOME}/s3"
	no_cache=''

	# ---
	# ---

	CHAR_OPTS=''
	LONG_OPTS='help'

	LONG_OPTS="${LONG_OPTS},onto:,at:,in:,on:"
	LONG_OPTS="${LONG_OPTS},no-cache,nocache,stream,streaming"

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.


			(--onto|--at|--in|--on)
				mount_point="$1" && shift
				;;

			(--no-cache|--nocache|--stream|--streaming)
				no_cache='1'
				;;

		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	location="$1" && shift
	[ -n "$location" ] || user-error 1 'empty LOCATION'


	[ "$#" == 0 ] || user-error 1 'invalid option(s)'

}

# ---
# ---


# Param cleanup.
#
'has?' ':' <<< "$location" || location="${location}:/"

's3?' "$mount_point" && { s3- "$mount_point" || user-error 1 'MOUNT_POINT not available' ;}
ls "$mount_point"/* &> /dev/null && user-error 1 'non-empty MOUNT_POINT'

remote="${location%%:*}"
rclone listremotes | 'has-line?' "${remote}:" || user-error 2 "unknown remote '${remote}'"

if [ -n "$no_cache" ]
	then { mkdir -p "$mount_point" && rclone mount "$location" "$mount_point" --daemon --vfs-cache-mode='off'                         --s3-directory-markers ;} || non-user-error 3 'mount failed'
	else { mkdir -p "$mount_point" && rclone mount "$location" "$mount_point" --daemon --vfs-cache-mode='full' --vfs-fast-fingerprint --s3-directory-markers ;} || non-user-error 3 'mount failed'
fi
