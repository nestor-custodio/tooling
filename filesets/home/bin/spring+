#! /bin/env bash
source '/home/nestor/bin/std.lib'

# ---

{ # -- Help Text -- #

	cat <<-EOF | store-as usage
		Usage: $( script-name )

		Starts a Ruby Spring server that outlives its spawning shell.


		Mandatory arguments to long options are mandatory for short options too.
		  --help                    Show this help text.


		Exit Status:
		  0  if OK,
		  1  if invalid option,
		  2  if unable to run spring,
		  3  if command not invoked from valid location.
	EOF

}

# ---

{ # -- Parameter Processing: Options -- #

	CHAR_OPTS=''
	LONG_OPTS='help'

	set-params
	while true; do
		option="$1" && shift
		case "$option" in
			(--help) help-and-exit ;;
			(--) break ;;  # No more options.
		esac
	done

}

{ # -- Parameter Processing: Positionals -- #

	[ "$#" == 0 ] || user-error 1 'invalid option(s)'

}

# ---
# ---


'dev?' || user-error 3 "not currently within '${DEV_ROOT}'"
cd "$( groot )" 2> /dev/null || cd "$DEV_ROOT"

command -v spring &> /dev/null || gem install spring || non-user-error 2 "unable to find (or set up) 'spring'"
spring stop &> /dev/null

spring_log='/var/log/spring.log'
sudo "$( real rotate )" "$spring_log" --max=5 --chmod=666
nohup spring server &> "$spring_log" &
